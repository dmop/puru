{
  "prettier.enable": false,
  "eslint.enable": false,
  "oxc.enable": true,
  "editor.defaultFormatter": "nicolo-ribaudo.biome-oxc",
  "editor.formatOnSave": true,
  "[typescript]": {
    "editor.defaultFormatter": "nicolo-ribaudo.biome-oxc",
    "editor.codeActionsOnSave": {
      "source.fixAll.oxc": "explicit"
    }
  },
  "[javascript]": {
    "editor.defaultFormatter": "nicolo-ribaudo.biome-oxc",
    "editor.codeActionsOnSave": {
      "source.fixAll.oxc": "explicit"
    }
  },
  "[json]": {
    "editor.defaultFormatter": "nicolo-ribaudo.biome-oxc"
  }
}
